{
  "openapi": "3.0.1",
  "info": {
    "title": "MealPlannerAPI",
    "version": "1.0"
  },
  "paths": {
    "/api/Recipe/generate": {
      "post": {
        "tags": [
          "Recipe"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecipeRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RecipeRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RecipeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RecipeRequest": {
        "type": "object",
        "properties": {
          "ingredients": {
            "type": "string",
            "nullable": true
          },
          "diet": {
            "type": "string",
            "nullable": true
          },
          "cuisine": {
            "type": "string",
            "nullable": true
          },
          "time": {
            "type": "integer",
            "format": "int32"
          },
          "servings": {
            "type": "integer",
            "format": "int32"
          },
          "mealType": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}